{
  "$schema": "https://ainative.studio/schemas/port-config.v1.json",
  "project_name": "OpenClaw",
  "description": "AI Agent Swarm Management Platform - Local Development Configuration",
  "services": [
    {
      "name": "Gateway",
      "description": "Node.js WebSocket Gateway with DBOS Durable Workflows",
      "port": 18789,
      "directory": "openclaw-gateway",
      "start_command": "npm start",
      "health_check": "http://localhost:{port}/health",
      "can_reassign": false,
      "required": true,
      "log_file": "/tmp/openclaw-gateway.log",
      "startup_message": "OpenClaw Gateway",
      "pre_start": null,
      "env_vars": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Backend",
      "description": "FastAPI Backend with Agent Lifecycle Management",
      "port": 8000,
      "directory": ".",
      "start_command": "python3 -m uvicorn backend.main:app --reload --host 0.0.0.0 --port {port}",
      "health_check": "http://localhost:{port}/health",
      "can_reassign": true,
      "required": true,
      "depends_on": ["Gateway"],
      "log_file": "/tmp/openclaw-backend.log",
      "startup_message": "Backend API (this includes agent initialization)",
      "pre_start": "python3 -c \"import fastapi, uvicorn\" 2>/dev/null || pip3 install -r requirements.txt",
      "env_vars": {
        "SECRET_KEY": "dev-secret-key-for-local-testing",
        "OPENCLAW_GATEWAY_URL": "http://localhost:{Gateway_port}",
        "OPENCLAW_GATEWAY_TOKEN": "openclaw-dev-token-12345",
        "ENVIRONMENT": "development",
        "DATABASE_URL": "sqlite:///./openclaw.db"
      },
      "post_start_checks": [
        {
          "description": "Agent initialization",
          "log_pattern": "✅ Agent initialization",
          "extract_pattern": "created|provisioned|already_exists",
          "display": "Main Agent: {match}"
        }
      ]
    },
    {
      "name": "Frontend",
      "description": "Next.js Dashboard (agent-swarm-monitor)",
      "port": 3002,
      "directory": "../agent-swarm-monitor",
      "start_command": "PORT={port} npm run dev",
      "health_check": "http://localhost:{port}",
      "can_reassign": true,
      "required": false,
      "depends_on": ["Backend"],
      "log_file": "/tmp/openclaw-frontend.log",
      "startup_message": "Frontend Dashboard",
      "pre_start": "[ -d node_modules ] || npm install",
      "env_updates": {
        ".env": {
          "NEXT_PUBLIC_API_URL": "http://localhost:{Backend_port}"
        }
      },
      "skip_if_missing": true,
      "missing_message": "Frontend directory not found at ../agent-swarm-monitor/. Skipping frontend startup."
    }
  ],
  "defaults": {
    "port_conflict_mode": "ask",
    "log_directory": "/tmp",
    "log_prefix": "openclaw",
    "startup_timeout": 30,
    "health_check_retries": 30,
    "health_check_interval": 1,
    "show_logs_on_error": true
  },
  "summary": {
    "show_service_urls": true,
    "show_port_configuration": true,
    "show_agent_verification": true,
    "verification_commands": [
      {
        "description": "Verify agents",
        "command": "curl http://localhost:{Backend_port}/api/v1/agents?limit=50 | python3 -m json.tool"
      }
    ],
    "additional_urls": [
      {
        "name": "API Docs",
        "url": "http://localhost:{Backend_port}/docs"
      }
    ],
    "mode_help": true,
    "open_browser": {
      "enabled": true,
      "url": "http://localhost:{Frontend_port}",
      "delay": 2
    }
  }
}
