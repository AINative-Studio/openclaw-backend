# OpenClaw Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Core Database Configuration
# =============================================================================

# PostgreSQL 14+ connection string (REQUIRED - No default, must be provided)
# Format: postgresql+asyncpg://username:password@host:port/database
# Example: postgresql+asyncpg://postgres:your-password@localhost:5432/openclaw
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD_HERE@your-host:5432/your-database

# =============================================================================
# REQUIRED: OpenClaw Gateway Connection
# =============================================================================

# OpenClaw Gateway WebSocket URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token (generate a secure random token)
# Example: openssl rand -hex 32
OPENCLAW_TOKEN=your-gateway-token-here

# =============================================================================
# REQUIRED: Security & Application Configuration
# =============================================================================

# Environment mode (development|staging|production|testing)
ENVIRONMENT=development

# Secret key for JWT signing and encryption (minimum 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-minimum-32-characters-here

# Token encryption key (base64 encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-base64-encoded-encryption-key-here

# CORS Security Configuration (CRITICAL)
# REQUIRED in production - comma-separated list of allowed frontend origins
# Development: Defaults to localhost:3000,3002 if not set
# Production: MUST be explicitly set (no wildcards allowed for security)
# Example: ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
# SECURITY WARNING: NEVER use "*" as it allows ANY website to steal user credentials
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# =============================================================================
# OPTIONAL: AI Provider API Keys
# =============================================================================

# Anthropic API (for NL command parsing)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API
OPENAI_API_KEY=sk-proj-your-key-here

# Google Gemini API
GEMINI_API_KEY=your-gemini-key-here

# Cohere API
COHERE_API_KEY=your-cohere-key-here

# Mistral API
MISTRAL_API_KEY=your-mistral-key-here

# Ollama API
OLLAMA_API_KEY=your-ollama-key-here

# Hume AI API
HUME_API_KEY=your-hume-api-key-here
HUME_SECRET_KEY=your-hume-secret-key-here

# =============================================================================
# OPTIONAL: Cloud Service Credentials
# =============================================================================

# AWS Credentials (for Braket quantum computing)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BRAKET_REGION=us-east-1

# AWS Braket Configuration
ENABLE_REAL_QUANTUM_HARDWARE=false
QUANTUM_DEVICE_TYPE=simulator
IONQ_ARIA_ARN=arn:aws:braket:us-east-1::device/qpu/ionq/Aria-1
IONQ_FORTE_ARN=arn:aws:braket:us-east-1::device/qpu/ionq/Forte-1
AWS_BRAKET_SIMULATOR_ARN=arn:aws:braket:::device/quantum-simulator/amazon/sv1
MAX_DAILY_QUANTUM_COST_USD=100.0
MAX_SHOTS_PER_CIRCUIT=1000
QUANTUM_COST_ALERT_THRESHOLD_USD=50.0

# MinIO Object Storage
MINIO_ENDPOINT=your-minio-endpoint
MINIO_URL=https://your-minio-url
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_SECURE=true
MINIO_REGION=us-east-1

# ZeroDB S3-Compatible Storage
ZERODB_S3_ENDPOINT=minio:9000
ZERODB_S3_BUCKET=quantum-results
ZERODB_S3_ACCESS_KEY=your-s3-access-key
ZERODB_S3_SECRET_KEY=your-s3-secret-key
ZERODB_S3_REGION=us-east-1
ZERODB_S3_USE_SSL=false
QUANTUM_RESULTS_RETENTION_DAYS=90
QUANTUM_RESULTS_COMPRESSION=true

# =============================================================================
# OPTIONAL: Payment & Financial Services
# =============================================================================

# Stripe API Keys (NEVER commit live keys)
STRIPE_SECRET_KEY=sk_test_your-test-key-here
STRIPE_PRIVATE_KEY=pk_test_your-test-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-test-publishable-key-here

# Sila Money
Client_ID=your-sila-client-id
Client_Secret=your-sila-client-secret

# BoomPay API
BOOMPAY_API_KEY=your-boompay-api-key

# =============================================================================
# OPTIONAL: Third-Party Service APIs
# =============================================================================

# Google Services
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-customer-id
GOOGLE_ADS_CUSTOMER_ID=your-customer-id

# Search APIs
SERPAPI_API_KEY=your-serpapi-key

# Productivity Tools
NOTION_API_KEY=your-notion-key
TRELLO_API_KEY=your-trello-key
TRELLO_TOKEN=your-trello-token

# Voice & Audio
ELEVENLABS_API_KEY=your-elevenlabs-key
SHERPA_ONNX_RUNTIME_DIR=path-to-sherpa-runtime
SHERPA_ONNX_MODEL_DIR=path-to-sherpa-models

# Design Tools
FIGMA_PERSONAL_ACCESS_TOKEN=your-figma-token

# =============================================================================
# OPTIONAL: GitHub Integration
# =============================================================================

# GitHub API Tokens
GITHUB_TOKEN=ghp_your-github-token-here
AGENT_SWARM_GITHUB_TOKEN=ghp_your-agent-swarm-token-here

# GitHub OAuth Configuration
VITE_GITHUB_CLIENT_ID=your-github-oauth-client-id
VITE_GITHUB_REDIRECT_URI=https://your-domain.com/login/callback
GitHub_User=your-github-username
GitHub_Pass=your-github-password
GitHub_Client_Secret=your-github-oauth-client-secret

# =============================================================================
# OPTIONAL: ZeroDB Integration
# =============================================================================

# ZeroDB API Configuration
ZERODB_API_URL=https://api.ainative.studio
ZERODB_API_KEY=your-zerodb-api-key
ZERODB_PROJECT_ID=your-project-id
ZERODB_USERNAME=your-zerodb-username
ZERODB_PASSWORD=your-zerodb-password

# =============================================================================
# OPTIONAL: Deployment & Infrastructure
# =============================================================================

# Railway Production
API_Key=your-railway-api-key
API_Base_URL=https://api.ainative.studio/
Vercel_Token=your-vercel-token

# Strapi CMS
STRAPI_URL=https://your-strapi-instance.com
STRAPI_ADMIN_URL=https://your-strapi-instance.com/admin
STRAPI_API_URL=https://your-strapi-instance.com/api

# =============================================================================
# OPTIONAL: Feature Flags & Configuration
# =============================================================================

# OpenClaw Mock Mode
OPENCLAW_MOCK_AGENT=false

# AI Kit Core Configuration
AIKIT_API_KEY=your-aikit-api-key
AIKIT_MODEL_VERSION=v1.0
AIKIT_ENABLE_ANALYTICS=true
AIKIT_MAX_WORKERS=4

# Core Cody Identity
CODY_IDENTITY_ENFORCEMENT=strict
CODY_NAME_OVERRIDE=Cody
CODY_CREATOR=AINative Studio
CODY_ROLE=Expert Software Architect
CODY_TEMPERATURE=0.7
CODY_TOP_P=0.9
CODY_REPETITION_PENALTY=1.1
CODY_MAX_TOKENS=4000

# ZeroDB Integration
CODY_DEFAULT_DATABASE=zerodb
CODY_ENFORCE_ZERODB=true
CODY_ZERODB_PRIORITY=high
CODY_DATABASE_FIRST_APPROACH=true

# Behavioral Settings
CODY_ARCHITECTURE_FIRST=true
CODY_TOOL_USAGE_PRIORITY=high
CODY_PROACTIVE_MODE=enabled
CODY_PRODUCTION_READY=true
CODY_RESPONSE_STYLE=action_first
CODY_CODE_QUALITY=production
CODY_EXPLANATION_LEVEL=concise
CODY_SUGGEST_IMPROVEMENTS=always

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# CRITICAL SECURITY RULES:
# 1. NEVER commit the actual .env file to version control
# 2. NEVER commit live/production API keys
# 3. Always use test/sandbox keys in development
# 4. Rotate all credentials if accidentally exposed
# 5. Use different credentials for each environment (dev/staging/prod)
# 6. Store production credentials in secure secret management (e.g., Railway secrets, AWS Secrets Manager)
#
# GENERATING SECURE KEYS:
# - Secret keys: openssl rand -hex 32
# - Encryption keys: openssl rand -base64 32
# - Tokens: openssl rand -hex 64
#
# IF CREDENTIALS ARE EXPOSED:
# 1. Immediately rotate ALL exposed credentials
# 2. Revoke the compromised keys at the provider
# 3. Check for unauthorized usage
# 4. Update this file and all environments with new credentials
# 5. Review git history and remove exposed credentials
#
# =============================================================================
