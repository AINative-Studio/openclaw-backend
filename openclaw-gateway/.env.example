# OpenClaw Gateway Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Server Configuration
# =============================================================================

# Gateway HTTP server port (must match backend OPENCLAW_GATEWAY_URL)
PORT=18789

# Server host address
HOST=127.0.0.1

# =============================================================================
# REQUIRED: Authentication
# =============================================================================

# Gateway authentication token (must match backend OPENCLAW_TOKEN)
# Generate with: openssl rand -hex 32
AUTH_TOKEN=your-gateway-auth-token-here

# =============================================================================
# REQUIRED: PostgreSQL Configuration
# =============================================================================
# CRITICAL: DBOS SDK reads PostgreSQL SSL configuration from environment
# variables, NOT from dbos-config.yaml!

# PostgreSQL host
PGHOST=your-postgres-host

# PostgreSQL port
PGPORT=5432

# PostgreSQL username
PGUSER=postgres

# PostgreSQL password
PGPASSWORD=your-postgres-password-here

# PostgreSQL database name
PGDATABASE=your-database-name

# PostgreSQL SSL mode (disable for Railway self-signed certificates)
# Options: disable, allow, prefer, require, verify-ca, verify-full
PGSSLMODE=disable

# PostgreSQL connection timeout (seconds)
PGCONNECT_TIMEOUT=10

# =============================================================================
# REQUIRED: Backend API Configuration
# =============================================================================

# Backend API base URL
BACKEND_URL=http://localhost:8000

# =============================================================================
# REQUIRED: Anthropic API
# =============================================================================

# Anthropic API key for AI operations
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# =============================================================================
# OPTIONAL: ZeroDB Memory MCP Configuration
# =============================================================================

# ZeroDB API endpoint
ZERODB_API_URL=https://api.ainative.studio

# ZeroDB authentication
ZERODB_USERNAME=your-zerodb-username
ZERODB_PASSWORD=your-zerodb-password

# ZeroDB project identifier
ZERODB_PROJECT_ID=your-project-id

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=30000

# Session timeout (milliseconds)
SESSION_TIMEOUT=3600000

# Maximum concurrent sessions
MAX_SESSIONS=1000

# Agent timeout (milliseconds)
AGENT_TIMEOUT=60000

# Maximum message size (bytes)
MAX_MESSAGE_SIZE=1048576

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# CRITICAL SECURITY RULES:
# 1. NEVER commit the actual .env file to version control
# 2. NEVER commit production database credentials
# 3. Always use different credentials for dev/staging/prod environments
# 4. Rotate all credentials if accidentally exposed
# 5. Store production credentials in Railway secrets or environment variables
#
# POSTGRESQL SSL CONFIGURATION:
# - Railway uses self-signed certificates, so PGSSLMODE=disable is required
# - The DBOS SDK reads PGSSLMODE from environment variables, NOT dbos-config.yaml
# - See docs/DBOS_GATEWAY_SETUP_IMPROVEMENTS.md for details
#
# GENERATING SECURE TOKENS:
# - Auth tokens: openssl rand -hex 32
# - Passwords: openssl rand -base64 32
#
# IF CREDENTIALS ARE EXPOSED:
# 1. Immediately rotate ALL exposed credentials
# 2. Revoke compromised keys at the provider (Anthropic, Railway, etc.)
# 3. Check for unauthorized database access
# 4. Update all environments with new credentials
# 5. Review git history and remove exposed credentials
#
# =============================================================================
